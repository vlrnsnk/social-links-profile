{
  "name": "social-links-profile",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Solution to the 'Social Links Profile' challenge on Frontend Mentor",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "stylelint": "stylelint \"src/scss/**/*.scss\"",
    "editorconfig": "npx editorconfig-cli",
    "lint": "npm run editorconfig && stylelint \"src/scss/**/*.scss\"",
    "lint:fix": "stylelint \"src/scss/**/*.scss\" --fix",
    "lint:html": "html-validate \"*.html\"",
    "lint:html:fix": "html-validate --fix \"*.html\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vlrnsnk/social-links-profile.git"
  },
  "keywords": [
    "frontendmentor",
    "vite",
    "sass",
    "frontend"
  ],
  "author": "Valeriy Anysenko",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vlrnsnk/social-links-profile/issues"
  },
  "homepage": "https://vlrnsnk.github.io/social-links-profile",
  "browserslist": [
    "last 2 versions",
    "not dead",
    "> 0.2%",
    "not ie <= 11",
    "not op_mini all"
  ],
  "editorconfig-cli": [
    "*.json",
    "*.js",
    "src/*.html",
    "src/sass/**/*.scss"
  ],
  "lint-staged": {
    "src/scss/**/*.scss": "stylelint --fix",
    "*.{js,json}": "npx editorconfig-cli",
    "*.html": "html-validate"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "editorconfig-cli": "^1.0.0",
    "html-validate": "^10.13.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "sass": "^1.97.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.13.0",
    "vite": "^7.2.4"
  }
}
